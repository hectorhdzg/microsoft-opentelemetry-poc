# =============================================================================
# Standard Environment Template
# =============================================================================
# Use this for local development without A365 agentic auth.
# Telemetry can go to console, OTLP (Jaeger), and/or Azure Monitor.
#
# Usage: cp .env.template .env
# =============================================================================

# --- Azure OpenAI (required) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=

# --- Agent Configuration ---
PORT=3978
LOG_LEVEL=INFO

# --- Observability ---
OBSERVABILITY_SERVICE_NAME=agent-framework-sample
OBSERVABILITY_SERVICE_NAMESPACE=agent-framework.samples
ENABLE_OTEL=true
ENABLE_OBSERVABILITY=true
ENABLE_SENSITIVE_DATA=true
PYTHON_ENVIRONMENT=development

# --- Azure Monitor (optional — fill in to enable) ---
# APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- OTLP Export (optional — requires Docker stack: docker compose -f docker/docker-compose.yml up -d) ---
# Jaeger UI: http://localhost:16686
# ENABLE_OTLP_EXPORTER=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- A365 (disabled) ---
ENABLE_A365_OBSERVABILITY_EXPORTER=false
ENABLE_A365_EXPORTER=false
